{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "node16",
    "jsx": "react-jsx",
    "allowSyntheticDefaultImports": true,
    "ignoreDeprecations": "6.0"
  },
  "exclude": [
    "node_modules",
    "client/node_modules",
    "server/node_modules",
    "dist",
    "**/dist",
    ".git"
  ]
}
